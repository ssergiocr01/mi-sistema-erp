generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// Modelo de Producto (El corazón del sistema)
model Product {
  id          String   @id @default(uuid())
  name        String
  sku         String   @unique
  description String?
  price       Decimal  @db.Decimal(18, 2)
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  
  movements   StockMovement[]
}

// Categorías para organizar productos
model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]
}

// Historial de Movimientos (Entradas y Salidas)
// Esto es lo que hace al sistema "profesional"
model StockMovement {
  id        String   @id @default(uuid())
  quantity  Int
  type      String   // "IN" (Entrada) o "OUT" (Salida)
  reason    String?  // Ej: "Venta", "Devolución", "Ajuste"
  createdAt DateTime @default(now())

  productId String
  product   Product  @relation(fields: [productId], references: [id])
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  password      String    // Para login con credenciales
  role          String    @default("USER") // "ADMIN" o "USER"
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
}

// Tablas requeridas por Auth.js para persistencia
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
